{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-save",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "fs:allow-write-text-file",
    "fs:allow-write",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-app-write",
    "fs:allow-app-read",
    "core:webview:allow-set-webview-zoom",
    "opener:allow-reveal-item-in-dir"
  ]
}
