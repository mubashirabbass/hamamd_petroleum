{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HR Filling Station Mobile",
  "version": "1.0.0",
  "identifier": "com.ebs.business.mobile.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HR Filling Station Mobile",
        "width": 450,
        "height": 800,
        "resizable": true,
        "zoomHotkeysEnabled": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preloadConnections": ["sqlite:ebs_business.db"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
